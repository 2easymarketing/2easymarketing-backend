# 2EasyMarketing launch environment variables
# Copy these into Railway/Vercel environment settings. Do not commit real values.

# Backend / database
DB_PATH=/app/2easymarketing.db
MEDIA_DIR=/app/media

# Owner login
OWNER_EMAIL=2easymarketing@gmail.com
# Use ONE of these. OWNER_PASSWORD is easiest; OWNER_PASSWORD_HASH is best for production.
OWNER_PASSWORD=replace_with_a_strong_private_password
OWNER_PASSWORD_HASH=
OWNER_SECRET=replace_with_random_secret
OWNER_SECRET_KEY=replace_with_random_fortress_secret

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
PPLX_API_KEY=

# Optional model overrides
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_AD_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro

# Email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_TO=2easymarketing@gmail.com
